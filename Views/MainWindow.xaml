<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Views="clr-namespace:Sonic.Views" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Sonic.MainWindow"
        Title="Sonic " Height="450" Width="700" WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_KeyDown"
        WindowStyle="None" AllowsTransparency="False" Foreground="{x:Null}" Background="{x:Null}" MinWidth="600" MinHeight="400">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="upmenu" Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MenuColumn" Width="Auto" MinWidth="0"/>
            <ColumnDefinition MinWidth="540"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="menugrid" Grid.Row="0" Grid.ColumnSpan="2" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <StackPanel x:Name="Panel" Orientation="Horizontal" Background="{DynamicResource UpThemeButtonBrush}">
                <Button Content="☰" Width="40" Background="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" FontSize="20" BorderThickness="0" Click="ToggleMenu_Click" Cursor="Hand" BorderBrush="{x:Null}"/>
                <TextBlock Text="Sonic — system optimizer" Foreground="{DynamicResource UpThemeTextBrush}" VerticalAlignment="Center" Margin="10,0" FontFamily="Algerian" FontSize="22" FontStyle="Italic"/>
            </StackPanel>
            <Button x:Name="ButtonCl" Content="✕" Margin="665,0,0,0" Background="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" Click="Button_Click" RenderTransformOrigin="2.668,-0.383" BorderBrush="{x:Null}" FontSize="24" Cursor="Hand" HorizontalAlignment="Right" Width="35"/>
            <Button x:Name="SizeButton" Content="🗖" Margin="625,0,35,0" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" FontSize="24" Click="size_Click" RenderTransformOrigin="-0.21,0.46" HorizontalAlignment="Right" VerticalContentAlignment="Top"/>
            <Button x:Name="hide" Content="—" Margin="584,0,75,2" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" FontSize="18" Cursor="Hand" Click="hide_Click" RenderTransformOrigin="0.732,0.51" HorizontalAlignment="Right"/>
        </Grid>

        <DockPanel x:Name="Lmenu" Grid.Row="1" LastChildFill="False" HorizontalAlignment="Center">
            <Button x:Name="ButtonD" Content="Діагностика" DockPanel.Dock="Top" Height="38" Width="127"
                    Background="{DynamicResource ThemeButtonBrush}"
                    FontFamily="Comic Sans MS" FontSize="18" Click="ButtonD_Click" Margin="0,10,0,0" Cursor="Hand" Foreground="{DynamicResource ThemeButtonTextBrush}" BorderBrush="{x:Null}"/>

            <Button x:Name="Cleanerbutton" Content="Очистити" DockPanel.Dock="Top" Height="38" Width="127" Margin="0,10,0,0"
                    Background="{DynamicResource ThemeButtonBrush}" Foreground="{DynamicResource ThemeButtonTextBrush}"
                    FontSize="18" Cursor="Hand" FontFamily="Comic Sans MS" Click="BClean_Click" BorderBrush="{x:Null}">
                <Button.DataContext>
                    <Views:CleanupPage/>
                </Button.DataContext>
            </Button>

            <Button x:Name="settingbutton" Content="Налаштування" DockPanel.Dock="Top" Height="38" Width="127" Margin="0,10,0,0"
                    Background="{DynamicResource ThemeButtonBrush}" Foreground="{DynamicResource ThemeButtonTextBrush}"
                    Cursor="Hand" FontSize="18" FontFamily="Comic Sans MS" Click="Button_Click_1" BorderBrush="{x:Null}"/>
        </DockPanel>

        <Frame x:Name="MainFrame" Content="Frame" Grid.Row="1" Source="/Views/DashboardPage.xaml" Grid.Column="1" Foreground="{x:Null}" NavigationUIVisibility="Hidden"/>
        <Button x:Name="exitbutton" Content="Вийти" Click ="Exit_Click" Grid.Row="1" Background="{DynamicResource ThemeButtonBrush}" Foreground="{DynamicResource ThemeButtonTextBrush}" BorderBrush="{x:Null}" FontFamily="Comic Sans MS" FontSize="18" Cursor="Hand" HorizontalAlignment="Center" Width="126" VerticalContentAlignment="Bottom" Height="29" VerticalAlignment="Bottom" Margin="0,0,0,10" Visibility="Hidden"/>
    </Grid>
</Window>