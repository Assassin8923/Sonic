<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Views="clr-namespace:Sonic.Views" x:Class="Sonic.MainWindow"
        Title="Sonic " Height="450" Width="700" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Foreground="{x:Null}" Background="{x:Null}">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition x:Name="upmenu" Height="40"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition x:Name="MenuColumn" Width="Auto"/>
			<ColumnDefinition/>
		</Grid.ColumnDefinitions>

		<Grid x:Name="menugrid" Grid.Row="0" Grid.ColumnSpan="2" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
			<StackPanel x:Name="Panel" Orientation="Horizontal" Background="{DynamicResource UpThemeButtonBrush}">
				<Button Content="☰" Width="40" Background="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" FontSize="20" BorderThickness="0" Click="ToggleMenu_Click" Cursor="Hand" BorderBrush="{x:Null}"/>
				<TextBlock Text="Sonic — system optimizer" Foreground="{DynamicResource UpThemeTextBrush}" VerticalAlignment="Center" Margin="10,0" FontFamily="Algerian" FontSize="22" FontStyle="Italic"/>
			</StackPanel>
			<Button x:Name="ButtonCl" Content="✕" Margin="665,0,0,0" Background="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" Click="Button_Click" RenderTransformOrigin="2.668,-0.383" BorderBrush="{x:Null}" FontSize="24" Cursor="Hand" HorizontalAlignment="Right" Width="35"/>
			<Button x:Name="Size" Content="▢" Margin="625,0,35,0" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" FontSize="24" Click="size_Click" RenderTransformOrigin="-0.21,0.46" HorizontalAlignment="Right"/>
			<Button x:Name="hide" Content="—" Margin="584,0,75,2" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" FontSize="18" Cursor="Hand" Click="hide_Click" RenderTransformOrigin="0.732,0.51" HorizontalAlignment="Right"/>
		</Grid>

		<DockPanel x:Name="Lmenu" Grid.Row="1" LastChildFill="False" HorizontalAlignment="Center" Width="134">
			<Button x:Name="ButtonD" Content="Діагностика" DockPanel.Dock="Top" Height="38" Width="127"
                    Background="{DynamicResource ThemeButtonBrush}" Foreground="White"
                    FontFamily="Comic Sans MS" FontSize="18" Click="ButtonD_Click" Margin="0,10,0,0" Cursor="Hand"/>

			<Button x:Name="Cleanerbutton" Content="Очистити" DockPanel.Dock="Top" Height="38" Width="127" Margin="0,6,0,0"
                    Background="{DynamicResource ThemeButtonBrush}" Foreground="White"
                    FontSize="18" Cursor="Hand" FontFamily="Comic Sans MS" Click="BClean_Click">
				<Button.DataContext>
					<Views:CleanupPage/>
				</Button.DataContext>
			</Button>

			<Button x:Name="settingbutton" Content="Налаштування" DockPanel.Dock="Top" Height="38" Width="127" Margin="0,10,0,0"
                    Background="{DynamicResource ThemeButtonBrush}" Foreground="White"
                    Cursor="Hand" FontSize="18" FontFamily="Comic Sans MS" Click="Button_Click_1"/>
		</DockPanel>

		<Frame x:Name="MainFrame" Content="Frame" Grid.Row="1" Source="/Views/DashboardPage.xaml" Grid.Column="1" Foreground="{x:Null}" NavigationUIVisibility="Hidden"/>
	</Grid>
</Window>