<Window x:Class="Sonic.Views.CustomMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Повідомлення" Height="200" Width="400" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize" 
        AllowsTransparency="True" Background="Transparent" Topmost="True">

    <Border Background="{DynamicResource ThemeBackgroundBrush}" 
            BorderBrush="{DynamicResource ThemeBackgroundBrush}" BorderThickness="1" 
            CornerRadius="8" Padding="5">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Grid_MouseLeftButtonDown" Background="Transparent">
                <TextBlock x:Name="TitleText" Text="Sonic" Foreground="{DynamicResource UpThemeTextBrush}" 
                           FontFamily="Algerian" FontSize="16" VerticalAlignment="Center" Margin="10,0"/>

                <Button Content="✕" Width="30" HorizontalAlignment="Right" Background="{x:Null}" 
                        BorderBrush="{x:Null}" Foreground="{DynamicResource UpThemeTextBrush}" 
                        FontSize="18" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>

            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Тут буде текст..." 
                       Foreground="{DynamicResource UpThemeTextBrush}" 
                       FontSize="16" FontFamily="Comic Sans MS"
                       TextWrapping="Wrap" TextAlignment="Center" 
                       VerticalAlignment="Center" Margin="20,10"/>

            <Button Grid.Row="2" Content="ОК" Width="100" Height="30" 
                    Foreground="{DynamicResource ThemeButtonBrush}" 
                    BorderBrush="{x:Null}" FontSize="16" FontFamily="Comic Sans MS" 
                    Cursor="Hand" Click="OkButton_Click" HorizontalAlignment="Center" Background="{x:Null}"/>
        </Grid>
    </Border>
</Window>