<Page x:Class="Sonic.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Sonic.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage">

    <Grid x:Name="background" Background="Transparent">
        <Label x:Name="Nlable1" Content="Налаштування" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Foreground="{DynamicResource ThemeTextBrush}" FontSize="48" FontFamily="Comic Sans MS" FontStyle="Italic" FontWeight="Bold"/>

        <Slider x:Name="Nslider" HorizontalAlignment="Left" Margin="75,111,0,0" VerticalAlignment="Top" Foreground="{DynamicResource ThemeTextBrush}" FontSize="18" FontFamily="Comic Sans MS" Maximum="1" TickFrequency="1" IsSnapToTickEnabled="True" Cursor="Hand" Width="66" Background="Transparent" BorderBrush="{x:Null}" ValueChanged="Nslider_ValueChanged"/>

        <Label x:Name="Nlable" Content="Темний" HorizontalAlignment="Left" Margin="171,99,0,0" VerticalAlignment="Top" Foreground="{DynamicResource ThemeTextBrush}" FontSize="24" Background="{x:Null}"/>
    </Grid>
</Page>