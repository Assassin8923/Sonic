<Page x:Class="Sonic.Views.CleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450"
      Title="CleanupPage" Width="456">

    <Grid x:Name="background" Background="Transparent" HorizontalAlignment="Center" Width="456" VerticalAlignment="Center" Height="450">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <ListBox ItemsSource="{Binding Options}" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Width="368" Height="180">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsAvailable}" FontSize="22" Height="48" Width="327" FontWeight="Bold" FontStyle="Italic" Cursor="Hand" Foreground="{DynamicResource ThemeButtonBrush}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button x:Name="CButton" Content="Очистити" Background="{DynamicResource ThemeButtonBrush}" Foreground="{DynamicResource ThemeButtonTextBrush}" Margin="86,356,0,0" FontSize="36" Height="52" VerticalAlignment="Top" Cursor="Hand" FontFamily="Comic Sans MS" HorizontalAlignment="Left" Width="260" BorderBrush="{x:Null}" Click="CButton_Click" IsEnabled="{Binding CanClean}"/>

        <Label x:Name="Choose" Content="Очищення системи, оберіть&#xD;&#xA;варіант очищення:" Foreground="{DynamicResource ThemeButtonBrush}" FontSize="28" Margin="32,10,0,0" RenderTransformOrigin="0.722,0.778" VerticalAlignment="Top" FontStyle="Italic" FontFamily="Comic Sans MS" HorizontalAlignment="Left" Width="383" Background="{x:Null}"/>
        <Border BorderBrush="{DynamicResource ThemeButtonBrush}" BorderThickness="1" Height="174" VerticalAlignment="Center" HorizontalAlignment="Center" Width="368"/>
        <TextBlock Text="{Binding SelectedItemsText}" Margin="20,320,20,0" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Top" Foreground="{DynamicResource ThemeButtonBrush}" FontSize="16"/>
        <TextBlock Text="{Binding StatusText}" Margin="20,415,20,0" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Top" Foreground="{DynamicResource ThemeButtonBrush}" FontSize="16"/>
    </Grid>
</Page>
