<Application x:Class="Sonic.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Sonic"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ThemeTextBrush" Color="Black"/>
        <SolidColorBrush x:Key="ThemeButtonBrush" Color="Red"/>
        <SolidColorBrush x:Key="UpThemeButtonBrush" Color="Black"/>
        <SolidColorBrush x:Key="UpThemeTextBrush" Color="Red"/>
        <SolidColorBrush x:Key="ThemeButtonTextBrush" Color="Black"/>
    </Application.Resources>
</Application>
