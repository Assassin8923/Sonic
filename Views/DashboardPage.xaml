<Page x:Class="Sonic.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage" Height="550" Width="660">

    <Grid x:Name="background" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" Width="660" Height="550">
        <Grid.RowDefinitions>
            <RowDefinition Height="223*"/>
            <RowDefinition Height="30*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TextD" Text="Діагностика системи" FontSize="36" FontWeight="SemiBold" Margin="0,126,0,0" Foreground="{DynamicResource ThemeButtonBrush}" VerticalAlignment="Top" Height="51" HorizontalAlignment="Center"/>
        <Border BorderBrush="{DynamicResource ThemeButtonBrush}" BorderThickness="1" CornerRadius="5" Padding="15" Height="103" HorizontalAlignment="Left" Margin="195,215,0,167" VerticalAlignment="Center">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                <TextBlock Text="Об'єм тимчасових файлів:" FontSize="16" Foreground="{DynamicResource ThemeButtonBrush}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtTempSize" Text="Обчислення..." FontSize="36" FontWeight="Bold" Foreground="{DynamicResource ThemeButtonBrush}" Margin="0,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <Border BorderBrush="{DynamicResource ThemeButtonBrush}" BorderThickness="1" Margin="161,16,161,10" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="{DynamicResource ThemeButtonBrush}" FontFamily="Comic Sans MS" FontSize="16" Margin="93,0,93,0" Height="19" VerticalAlignment="Center"><Run Language="uk-ua" Text="Статус обчислення."/></TextBlock>
        </Border>
    </Grid>
</Page>