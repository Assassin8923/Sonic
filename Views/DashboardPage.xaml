<Page x:Class="Sonic.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DashboardPage">
    <Grid Background="Black">
        <StackPanel Margin="30">
            <TextBlock Text="Діагностика системи" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="Red"/>

            <Border Background="Red" BorderBrush="#DEB887" BorderThickness="1" CornerRadius="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Об'єм тимчасових файлів:" FontSize="16" Foreground="Black"/>
                    <TextBlock x:Name="TxtTempSize" Text="Обчислення..." FontSize="36" FontWeight="Bold" Foreground="Black" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Button x:Name="BtnRefresh" Content="🔄 Оновити дані" Width="150" Height="35" Margin="0,20,0,0" HorizontalAlignment="Left" Click="BtnRefresh_Click" Background="Red"/>
        </StackPanel>
    </Grid>
</Page>